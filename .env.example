# OpenAI API key (for planner / verifier backends)
OPENAI_API_KEY=

# Google Gemini API key (for vision backend)
GEMINI_API_KEY=

# Langfuse observability (optional — tracing is disabled if not set)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=  # e.g. https://cloud.langfuse.com or your self-hosted URL
